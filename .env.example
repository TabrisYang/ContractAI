# 複製成 .env 後再依需求調整；每一項都有預設值，沒有 .env 也能啟動。
# 對應 src/core/config.py 的 Settings。

# ── 應用程式 ────────────────────────────────────────────────
APP_NAME=合約去識別化系統
DEBUG=True

# ── Redis（Celery broker）────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── 模型 ───────────────────────────────────────────────────
# zh_core_web_sm：15MB，快，預設值
# zh_core_web_trf：415MB，較準，建議有 GPU 再用
SPACY_MODEL=zh_core_web_sm

# ── 去識別化 ────────────────────────────────────────────────
# TF-IDF 罕見詞閾值；未訓練 models/tfidf.pkl 時此功能自動略過
RARE_TERM_THRESHOLD=0.02

# ── .doc 轉檔（選用）────────────────────────────────────────
# 留空會自動偵測 soffice / libreoffice；找不到時再指定絕對路徑
LIBREOFFICE_BIN=

# ── RAG / 合約生成（選用）───────────────────────────────────
# 放置原始 .docx 合約的資料夾，供 index_contracts.py 建立向量索引。
# 預設為 repo 外層的 ../contracts；沒有這個資料夾時，
# 對話助手與合約生成會回 503，其餘功能不受影響。
# CONTRACTS_SOURCE_DIR=/絕對路徑/你的合約資料夾
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
RAG_TOP_K=4

# ── FastAPI ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
